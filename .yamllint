---
extends: default

ignore: |
  .planning/
  .claude/
  .codex/
  .help/
  dist/

rules:
  # GitHub Actions `on:` parses as YAML 1.1 boolean `true`; don't lint keys as truthy.
  truthy:
    check-keys: false
    allowed-values: ['true', 'false']
  # Actions `run:` lines and URLs get long; warn, don't fail the gate.
  line-length:
    max: 120
    level: warning
    allow-non-breakable-words: true
  # Workflow / config files routinely omit the leading `---`.
  document-start: disable
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable

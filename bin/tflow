#!/usr/bin/env node
// ESM (package.json "type":"module"). The tflow installer: copies the skill
// payload into Claude/Codex runtime skill dirs with a sha256 no-clobber manifest.
import {
  copyFileSync, mkdirSync, readdirSync, readFileSync, writeFileSync, existsSync,
  rmSync, rmdirSync, statSync,
} from 'node:fs';
import { createHash } from 'node:crypto';
import { spawnSync } from 'node:child_process';
import { parseArgs } from 'node:util';
import { homedir } from 'node:os';
import { dirname, join, relative, resolve, basename, sep } from 'node:path';
import { fileURLToPath } from 'node:url';

// ── Package-root + payload resolution (generalizes the Phase-4 stub) ──────────
// Works under npx, `npm i -g`/`npm link` (bin realpath), and a local checkout.
const pkgRoot = join(dirname(fileURLToPath(import.meta.url)), '..');
const payload = join(pkgRoot, 'skills');
const pkg = JSON.parse(readFileSync(join(pkgRoot, 'package.json'), 'utf8'));

const REAL_SKILLS = ['tflow-research', 'tflow-skill-creator', 'tflow-skill-factory'];

function usage(msg) {
  if (msg) console.error(`tflow: ${msg}`);
  console.error(
    'Usage: tflow init [--claude] [--codex] [--global] [--dry-run] [--force] [--uninstall]',
  );
}

// ── Payload exclusion (D-10) ──────────────────────────────────────────────────
// The ONLY required prune is scripts/fixtures/. `fail-*` is defensive insurance.
// `.npmignore`/`.gitignore` are packaging control files that npm strips from the
// published tarball — exclude them so a local-checkout install matches an npx one
// and no dev-kit control file lands in a runtime skill dir.
const isExcluded = (abs) => {
  if (abs.includes(`${sep}scripts${sep}fixtures`)) return true;
  const b = basename(abs);
  if (b.startsWith('fail-')) return true;
  if (b === '.npmignore' || b === '.gitignore') return true;
  return false;
};

// Recursive walk → forward-slash relative paths (stable manifest keys across OSes).
function walk(root, dir = root, out = []) {
  for (const e of readdirSync(dir, { withFileTypes: true })) {
    const abs = join(dir, e.name);
    if (isExcluded(abs)) continue;
    if (e.isDirectory()) walk(root, abs, out);
    else if (e.isFile()) out.push(relative(root, abs).split(sep).join('/'));
  }
  return out;
}

// sha256 of RAW BYTES — content-only (exec bit / newlines don't affect it).
const sha256 = (p) => createHash('sha256').update(readFileSync(p)).digest('hex');

function readManifest(manifestPath) {
  if (!existsSync(manifestPath)) return { files: {} };
  try {
    const m = JSON.parse(readFileSync(manifestPath, 'utf8'));
    // WR-05: require `files` to be a plain object — a string/array would pass a
    // truthy check and make Object.entries iterate garbage keys downstream.
    return m && typeof m === 'object' && m.files
      && typeof m.files === 'object' && !Array.isArray(m.files) ? m : { files: {} };
  } catch {
    return { files: {} };
  }
}

// Explicit --claude/--codex win (D-02). Bare init auto-detects existing runtime
// dirs under base; never auto-creates one (D-01).
function resolveRuntimes(values, base) {
  const explicit = [];
  if (values.claude) explicit.push('claude');
  if (values.codex) explicit.push('codex');
  if (explicit.length) return explicit;
  return ['claude', 'codex'].filter((r) => existsSync(join(base, `.${r}`)));
}

function installRuntime(runtime, targetRoot, scope, values) {
  const skillsDest = join(targetRoot, 'skills');
  const manifestPath = join(targetRoot, '.tflow', 'install-manifest.json');
  const manifest = readManifest(manifestPath);
  const rels = walk(payload);
  const newFiles = {};
  let created = 0;
  let overwritten = 0;
  let skipped = 0;

  // WR-02: persist whatever has actually been written so far. Invoked from a
  // finally so a copy that throws mid-loop (disk full, EXDEV, permissions) still
  // leaves a manifest recording the files already on disk — keeping them
  // self-healable on the next run and removable via --uninstall.
  const persistManifest = () => {
    const out = {
      name: pkg.name,
      version: pkg.version,
      runtime,
      scope,
      installedAt: new Date().toISOString(),
      files: newFiles,
    };
    mkdirSync(dirname(manifestPath), { recursive: true });
    writeFileSync(manifestPath, `${JSON.stringify(out, null, 2)}\n`);
  };

  console.log(`\n[${runtime}] ${values['dry-run'] ? 'dry-run ' : ''}install → ${targetRoot}`);
  try {
    for (const rel of rels) {
      const src = join(payload, ...rel.split('/'));
      const dest = join(skillsDest, ...rel.split('/'));
      const key = `skills/${rel}`;

      let action;
      if (!existsSync(dest)) {
        action = 'create';
      } else {
        const recorded = manifest.files[key];
        const instSha = sha256(dest);
        if (recorded && instSha === recorded) action = 'overwrite'; // pristine refresh (D-03)
        else action = values.force ? 'overwrite' : 'skip'; // user-modified (D-03/D-04)
      }

      if (action === 'create') created++;
      else if (action === 'overwrite') overwritten++;
      else skipped++;
      console.log(`  ${action === 'skip' ? 'skip(modified)' : action} ${key}`);

      if (values['dry-run'] || action === 'skip') continue;
      mkdirSync(dirname(dest), { recursive: true });
      copyFileSync(src, dest); // byte-exact, mode-preserving
      // WR-03: record a manifest entry only for files tflow actually created or
      // overwrote — never for skip(modified) or pre-existing user files — so
      // uninstall can't delete a path tflow never wrote.
      newFiles[key] = sha256(src);
    }
  } finally {
    if (!values['dry-run']) persistManifest(); // WR-02: flush even on partial failure
  }
  console.log(`  → ${created} created, ${overwritten} overwritten, ${skipped} skipped`);

  if (values['dry-run']) return; // D-05: write nothing

  // WR-04: prune files recorded by the PREVIOUS manifest that are absent from
  // the new payload (e.g. dropped in an upgrade) when they are still pristine,
  // so they don't become un-cleanable orphans. Modified files are preserved.
  // Mirrors the uninstall key-confinement guards (V12 + WR-01).
  const orphanDirs = new Set();
  for (const [key, recordedSha] of Object.entries(manifest.files)) {
    if (Object.prototype.hasOwnProperty.call(newFiles, key)) continue;
    const file = resolve(targetRoot, ...key.split('/'));
    if (!key || file === targetRoot || !file.startsWith(targetRoot + sep)) continue;
    try {
      if (existsSync(file) && statSync(file).isFile() && sha256(file) === recordedSha) {
        rmSync(file);
        orphanDirs.add(dirname(file));
        console.log(`  removed(orphan) ${key}`);
      }
    } catch {
      /* leave anything we can't classify cleanly */
    }
  }
  if (orphanDirs.size) pruneEmptyDirs(orphanDirs, targetRoot);
}

// Remove now-empty installer-created dirs bottom-up, confined under stopRoot.
function pruneEmptyDirs(dirs, stopRoot) {
  const all = new Set();
  for (let d of dirs) {
    while (d && d !== stopRoot && d.startsWith(stopRoot + sep)) {
      all.add(d);
      d = dirname(d);
    }
  }
  for (const d of [...all].sort((a, b) => b.length - a.length)) {
    try {
      if (existsSync(d) && readdirSync(d).length === 0) rmdirSync(d);
    } catch {
      /* not empty or already gone — leave it */
    }
  }
}

// --uninstall (D-07): remove only manifest-matching pristine files; preserve
// user-modified ones; then prune the manifest + empty installer-created dirs.
function uninstallRuntime(runtime, targetRoot) {
  const manifestPath = join(targetRoot, '.tflow', 'install-manifest.json');
  console.log(`\n[${runtime}] uninstall → ${targetRoot}`);
  if (!existsSync(manifestPath)) {
    console.error(`  WARN: no install manifest at ${manifestPath} — nothing to uninstall.`);
    return;
  }
  const manifest = readManifest(manifestPath);
  const touchedDirs = new Set();
  let removed = 0;
  let preserved = 0;
  let missing = 0;

  for (const [key, recordedSha] of Object.entries(manifest.files)) {
    // Security V12: confine each manifest key under targetRoot — reject `..`
    // escapes. WR-01: also reject empty/dot keys (resolve to targetRoot itself),
    // which would otherwise fall through to sha256() on a directory.
    const file = resolve(targetRoot, ...key.split('/'));
    if (!key || file === targetRoot || !file.startsWith(targetRoot + sep)) {
      console.error(`  reject ${key} (invalid manifest key)`);
      continue;
    }
    if (!existsSync(file)) {
      console.log(`  missing ${key}`);
      missing++;
    } else if (statSync(file).isFile() && sha256(file) === recordedSha) {
      rmSync(file);
      touchedDirs.add(dirname(file));
      console.log(`  removed ${key}`);
      removed++;
    } else {
      console.log(`  preserved(modified) ${key}`);
      preserved++;
    }
  }

  rmSync(manifestPath, { force: true });
  touchedDirs.add(dirname(manifestPath));
  touchedDirs.add(join(targetRoot, 'skills'));
  pruneEmptyDirs(touchedDirs, targetRoot);
  console.log(`  → ${removed} removed, ${preserved} preserved, ${missing} missing`);
}

// Advisory validate.sh self-check (D-08/D-09): run the INSTALLED creator
// validator against each installed real skill. sh missing → skip with a warning;
// any FAIL is advisory only — the install still exits 0.
function selfCheck(runtime, targetRoot) {
  const skillsDest = join(targetRoot, 'skills');
  const validate = join(skillsDest, 'tflow-skill-creator', 'scripts', 'validate.sh');
  if (spawnSync('sh', ['-c', 'exit 0']).error?.code === 'ENOENT') {
    console.error('WARN: POSIX sh unavailable — skipping validate.sh self-check.');
    return;
  }
  if (!existsSync(validate)) {
    console.error('WARN: validate.sh not present in install — skipping self-check.');
    return;
  }
  console.log(`[${runtime}] validate.sh self-check:`);
  for (const name of REAL_SKILLS) {
    const skillDir = join(skillsDest, name);
    if (!existsSync(skillDir)) continue;
    const r = spawnSync('sh', [validate, skillDir], { encoding: 'utf8' }); // argv array — no shell
    console.log(`  ${r.status === 0 ? 'PASS' : 'FAIL'} ${name}`);
  }
}

function main() {
  let parsed;
  try {
    parsed = parseArgs({
      allowPositionals: true,
      strict: true,
      options: {
        claude: { type: 'boolean' },
        codex: { type: 'boolean' },
        global: { type: 'boolean' },
        'dry-run': { type: 'boolean' },
        uninstall: { type: 'boolean' },
        force: { type: 'boolean' },
      },
    });
  } catch (err) {
    usage(err.message);
    process.exit(2);
  }

  const { values, positionals } = parsed;
  if (positionals[0] !== 'init') {
    usage(positionals.length ? `unknown command '${positionals[0]}'` : 'missing command');
    process.exit(2);
  }

  const base = values.global ? homedir() : process.cwd();
  const scope = values.global ? 'global' : 'local';
  const runtimes = resolveRuntimes(values, base);
  if (runtimes.length === 0) {
    usage('no runtime detected — pass --claude and/or --codex (no .claude/.codex to auto-detect)');
    process.exit(1);
  }

  for (const r of runtimes) {
    const targetRoot = join(base, `.${r}`);
    if (values.uninstall) {
      uninstallRuntime(r, targetRoot);
    } else {
      installRuntime(r, targetRoot, scope, values);
      if (!values['dry-run']) selfCheck(r, targetRoot); // advisory; never changes exit code
    }
  }
  process.exit(0); // self-check FAIL is advisory (D-08) — always exit 0
}

main();
